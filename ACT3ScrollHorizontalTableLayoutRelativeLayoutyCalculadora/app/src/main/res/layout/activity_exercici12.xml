<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#3949AB"
            android:gravity="center_vertical"
            android:paddingStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exercici 12 — Table / Grid / Linear"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ==================== PART 1: TableLayout ==================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. TableLayout"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:background="#C5CAE9"
            android:padding="12dp"/>

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
            android:shrinkColumns="1"
            android:padding="8dp">

            <!-- Fila 1: 3 cel·les iguals -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="56dp">
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="#E53935"
                    android:layout_margin="2dp"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="#8E24AA"
                    android:layout_margin="2dp"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="#1E88E5"
                    android:layout_margin="2dp"/>
            </TableRow>

            <!-- Fila 2: 3 cel·les iguals -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="56dp">
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="#F4511E"
                    android:layout_margin="2dp"/>
                <!-- Columna central: shrinkColumns="1" la comprimirà si cal -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="#00897B"
                    android:layout_margin="2dp"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="#FFB300"
                    android:layout_margin="2dp"/>
            </TableRow>

            <!-- Fila 3: cel·la petita + cel·la span=2 (ocupa 2 columnes) -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="56dp">
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="#43A047"
                    android:layout_margin="2dp"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:layout_span="2"
                    android:background="#039BE5"
                    android:layout_margin="2dp"/>
            </TableRow>

        </TableLayout>

        <!-- ==================== PART 2: GridLayout ==================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. GridLayout"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:background="#C5CAE9"
            android:padding="12dp"
            android:layout_marginTop="8dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3"
            android:padding="8dp"
            android:useDefaultMargins="false">

            <!-- Fila 1 -->
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:background="#E53935"
                android:layout_margin="2dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:background="#8E24AA"
                android:layout_margin="2dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:background="#1E88E5"
                android:layout_margin="2dp"/>

            <!-- Fila 2 -->
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:background="#F4511E"
                android:layout_margin="2dp"/>
            <!-- Columna central (es comprimirà) -->
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:background="#00897B"
                android:layout_margin="2dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:background="#FFB300"
                android:layout_margin="2dp"/>

            <!-- Fila 3: 1a cel·la + cel·la ampla (2 columnes) -->
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:background="#43A047"
                android:layout_margin="2dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="2"
                android:layout_columnSpan="2"
                android:background="#039BE5"
                android:layout_margin="2dp"/>

        </GridLayout>

        <!-- ==================== PART 3: LinearLayouts combinats ==================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. LinearLayouts combinats"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:background="#C5CAE9"
            android:padding="12dp"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Fila 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#E53935"
                    android:layout_marginEnd="2dp"/>
                <!-- Columna central amb shrinkable -->
                <View
                    android:id="@+id/viewCentralFila1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#8E24AA"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#1E88E5"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>

            <!-- Fila 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#F4511E"
                    android:layout_marginEnd="2dp"/>
                <!-- Columna central (shrinkColumns equivalent) -->
                <View
                    android:id="@+id/viewCentralFila2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#00897B"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#FFB300"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>

            <!-- Fila 3: 2 cel·les -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal">
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#43A047"
                    android:layout_marginEnd="2dp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:background="#039BE5"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <View android:layout_height="24dp" android:layout_width="match_parent"/>

    </LinearLayout>
</ScrollView>
