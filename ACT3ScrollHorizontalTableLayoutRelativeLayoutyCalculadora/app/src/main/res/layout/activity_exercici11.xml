<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#3949AB"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Exercici 11 — Scroll Horitzontal"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mostrar barres de scroll"
            android:textSize="14sp"
            android:textColor="#333333"/>

        <Switch
            android:id="@+id/switchScroll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <!-- Explicació -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Desplaça's horitzontalment per veure tots els botons:"
        android:textSize="13sp"
        android:textColor="#666666"/>

    <!-- HorizontalScrollView amb 7 botons -->
    <HorizontalScrollView
        android:id="@+id/horizontalScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbarStyle="insideOverlay"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn1"
                android:layout_width="120dp"
                android:layout_height="56dp"
                android:text="Botó 1"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn2"
                android:layout_width="120dp"
                android:layout_height="56dp"
                android:text="Botó 2"
                android:textColor="#FFFFFF"
                android:backgroundTint="#8E24AA"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn3"
                android:layout_width="120dp"
                android:layout_height="56dp"
                android:text="Botó 3"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E88E5"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn4"
                android:layout_width="120dp"
                android:layout_height="56dp"
                android:text="Botó 4"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00897B"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn5"
                android:layout_width="120dp"
                android:layout_height="56dp"
                android:text="Botó 5"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F4511E"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn6"
                android:layout_width="120dp"
                android:layout_height="56dp"
                android:text="Botó 6"
                android:textColor="#FFFFFF"
                android:backgroundTint="#039BE5"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn7"
                android:layout_width="120dp"
                android:layout_height="56dp"
                android:text="Botó 7"
                android:textColor="#FFFFFF"
                android:backgroundTint="#43A047"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Info estat -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Barres de scroll: VISIBLES"
        android:textSize="13sp"
        android:textColor="#3949AB"
        android:textStyle="italic"/>

</LinearLayout>
